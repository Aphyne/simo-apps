PORT=8000
NODE_ENV=development

# Salin dari Neon dashboard — format: postgresql://user:pass@host/db?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://username:password@ep-xxx.neon.tech/dbname?sslmode=require&channel_binding=require

# Ganti dengan random string panjang (min 32 karakter), jangan pakai nilai di bawah ini di production
JWT_SECRET=ganti_dengan_random_string_yang_panjang_dan_tidak_mudah_ditebak
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000
